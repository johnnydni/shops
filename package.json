{
  "name": "ritmo-shop",
  "version": "1.0.0",
  "private": true,
  "description": "RITMO Padel Shop — Vite + React + TS SPA. Static-friendly, deploys to GitHub Pages.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/asset-index.mjs && vite",
    "build": "node scripts/asset-index.mjs && tsc -b && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "assets:index": "node scripts/asset-index.mjs"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
